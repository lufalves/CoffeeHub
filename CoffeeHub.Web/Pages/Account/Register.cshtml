@page
@model CoffeeHub.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = S["RegisterFormHeading"].Value;
}

<section class="auth-shell">
    <div class="auth-panel auth-panel-brand">
        <span class="auth-kicker">@S["RegisterKicker"]</span>
        <h1>@S["RegisterHeading"]</h1>
        <p>@S["RegisterDesc"]</p>

        <div class="auth-highlights">
            <div>
                <strong>@S["RegisterHighlightProfileTitle"]</strong>
                <span>@S["RegisterHighlightProfileDesc"]</span>
            </div>
            <div>
                <strong>@S["RegisterHighlightSimpleTitle"]</strong>
                <span>@S["RegisterHighlightSimpleDesc"]</span>
            </div>
            <div>
                <strong>@S["RegisterHighlightGrowTitle"]</strong>
                <span>@S["RegisterHighlightGrowDesc"]</span>
            </div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form">
        <div class="auth-form-header">
            <span class="auth-badge">@S["RegisterBadge"]</span>
            <h2>@S["RegisterFormHeading"]</h2>
            <p>@S["RegisterFormDesc"]</p>
        </div>

        <form method="post" class="auth-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <label class="auth-field">
                <span>@S["Name"]</span>
                <input asp-for="Input.Name" class="form-control auth-input" placeholder="@S["RegisterNamePlaceholder"]" />
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
            </label>

            <label class="auth-field">
                <span>@S["Email"]</span>
                <input asp-for="Input.Email" class="form-control auth-input" placeholder="@S["RegisterEmailPlaceholder"]" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </label>

            <label class="auth-field">
                <span>@S["Password"]</span>
                <input asp-for="Input.Password" class="form-control auth-input" placeholder="@S["RegisterPasswordPlaceholder"]" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </label>

            <label class="auth-field">
                <span>@S["ConfirmPassword"]</span>
                <input asp-for="Input.ConfirmPassword" class="form-control auth-input" placeholder="@S["RegisterConfirmPlaceholder"]" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </label>

            <button type="submit" class="auth-submit">@S["RegisterSubmit"]</button>

            <p class="auth-helper">
                @S["RegisterAlreadyRegistered"]
                <a asp-page="/Account/Login">@S["RegisterGoToLogin"]</a>
            </p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
