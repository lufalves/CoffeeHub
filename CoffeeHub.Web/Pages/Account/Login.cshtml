@page
@model CoffeeHub.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = S["LoginPageTitle"];
}

<section class="auth-shell">
    <div class="auth-panel auth-panel-brand">
        <span class="auth-kicker">@S["LoginBrandKicker"]</span>
        <h1>@S["LoginBrandTagline"]</h1>
        <p>@S["LoginBrandDesc"]</p>

        <div class="auth-highlights">
            <div>
                <strong>@S["LoginHighlightCatalogTitle"]</strong>
                <span>@S["LoginHighlightCatalogDesc"]</span>
            </div>
            <div>
                <strong>@S["LoginHighlightReviewsTitle"]</strong>
                <span>@S["LoginHighlightReviewsDesc"]</span>
            </div>
            <div>
                <strong>@S["LoginHighlightRecipesTitle"]</strong>
                <span>@S["LoginHighlightRecipesDesc"]</span>
            </div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form">
        <div class="auth-form-header">
            <span class="auth-badge">@S["LoginEarlyAccess"]</span>
            <h2>@S["LoginFormHeading"]</h2>
            <p>@S["LoginFormSubheading"]</p>
        </div>

        <form method="post" class="auth-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <label class="auth-field">
                <span>@S["Email"]</span>
                <input asp-for="Input.Email" class="form-control auth-input" placeholder="@S["LoginEmailPlaceholder"]" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </label>

            <label class="auth-field">
                <span>@S["Password"]</span>
                <input asp-for="Input.Password" class="form-control auth-input" placeholder="@S["LoginPasswordPlaceholder"]" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </label>

            <label class="auth-check">
                <input asp-for="Input.RememberMe" />
                <span>@S["LoginRememberMe"]</span>
            </label>

            <button type="submit" class="auth-submit">@S["LoginSubmit"]</button>

            <p class="auth-helper">
                @S["LoginNoAccount"]
                <a asp-page="/Account/Register">@S["LoginCreateAccount"]</a>
            </p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
