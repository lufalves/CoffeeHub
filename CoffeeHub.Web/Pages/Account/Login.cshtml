@page
@model CoffeeHub.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
    <div class="auth-panel auth-panel-brand">
        <span class="auth-kicker">CoffeeHub</span>
        <h1>Track remarkable coffees, recipes, and reviews in one place.</h1>
        <p>
            Start with a focused personal workspace for coffee discovery, tasting notes,
            and future social features.
        </p>

        <div class="auth-highlights">
            <div>
                <strong>Catalog coffees</strong>
                <span>Origins, roasteries, roast levels, and brewing context.</span>
            </div>
            <div>
                <strong>Write reviews</strong>
                <span>Ratings and tasting impressions designed to grow over time.</span>
            </div>
            <div>
                <strong>Save recipes</strong>
                <span>Brewing methods, ratios, and repeatable preparation notes.</span>
            </div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form">
        <div class="auth-form-header">
            <span class="auth-badge">Early access</span>
            <h2>Login</h2>
            <p>Use your CoffeeHub account to enter the platform.</p>
        </div>

        <form method="post" class="auth-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <label class="auth-field">
                <span>Email</span>
                <input asp-for="Input.Email" class="form-control auth-input" placeholder="you@coffeehub.dev" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </label>

            <label class="auth-field">
                <span>Password</span>
                <input asp-for="Input.Password" class="form-control auth-input" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </label>

            <label class="auth-check">
                <input asp-for="Input.RememberMe" />
                <span>Keep me signed in on this device</span>
            </label>

            <button type="submit" class="auth-submit">Enter CoffeeHub</button>

            <p class="auth-helper">
                New around here?
                <a asp-page="/Account/Register">Create an account</a>
            </p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
