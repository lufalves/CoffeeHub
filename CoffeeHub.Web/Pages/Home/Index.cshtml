@page
@model CoffeeHub.Web.Pages.Home.IndexModel
@{
    ViewData["Title"] = S["Home"];
}

<section class="home-hero">
    <div>
        <span class="home-kicker">@S["HomeKicker"]</span>
        <h1>@S["HomeHeroTagline"]</h1>
        <p class="home-lead">@S["HomeHeroDesc"]</p>
    </div>

    <div class="home-card home-card-welcome">
        <span class="home-card-label">@S["SignedInAs"]</span>
        <strong>@Model.WelcomeName</strong>
        <p>@Model.Coffees.Count @S[Model.Coffees.Count == 1 ? "HomeCoffeeCountSingular" : "HomeCoffeeCountPlural"] @S["HomeCoffeeCountSuffix"]</p>
    </div>
</section>

<section class="home-section-header">
    <div>
        <span class="home-card-label">@S["HomeCatalogSectionLabel"]</span>
        <h2>@S["HomeAllCoffees"]</h2>
    </div>
    <div class="home-section-actions">
        <p>@S["HomeCatalogOrderNote"]</p>
        <a class="coffeehub-nav-button" asp-page="/Coffees/Index">@S["ManageCoffees"]</a>
    </div>
</section>

@if (Model.Coffees.Count == 0)
{
    <section class="home-empty-state">
        <h3>@S["HomeEmptyStateTitle"]</h3>
        <p>@S["HomeEmptyStateDesc"]</p>
    </section>
}
else
{
    <section class="coffee-feed">
        @foreach (var coffee in Model.Coffees)
        {
            <article class="coffee-feed-card">
                <div class="coffee-feed-top">
                    <span class="coffee-feed-chip">@S["HomeCardCoffeeChip"]</span>
                    <span class="coffee-feed-date">@coffee.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                </div>

                <h3>@coffee.Name</h3>

                @if (!string.IsNullOrWhiteSpace(coffee.Description))
                {
                    <p>@coffee.Description</p>
                }
                else
                {
                    <p class="coffee-feed-muted">@S["NoDescription"]</p>
                }

                <dl class="coffee-feed-meta">
                    <div>
                        <dt>@S["Barcode"]</dt>
                        <dd>@coffee.Barcode</dd>
                    </div>
                    <div>
                        <dt>@S["Roastery"]</dt>
                        <dd>@(coffee.Roastery?.Name ?? S["NotInformed"])</dd>
                    </div>
                    <div>
                        <dt>@S["Origin"]</dt>
                        <dd>@(coffee.Origin?.Region ?? S["NotInformed"])</dd>
                    </div>
                    <div>
                        <dt>@S["RoastLevel"]</dt>
                        <dd>@(coffee.RoastLevel?.Name ?? S["NotInformed"])</dd>
                    </div>
                </dl>
            </article>
        }
    </section>
}
