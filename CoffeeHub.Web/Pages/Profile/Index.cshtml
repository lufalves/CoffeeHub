@page
@model CoffeeHub.Web.Pages.Profile.IndexModel
@{
    ViewData["Title"] = S["Profile"].Value;

    var user = Model.CurrentUser;
    var displayName = user?.Name ?? User.Identity?.Name ?? "CoffeeHub User";
    var memberSince = user == null || user.CreatedAt == default
        ? S["Unknown"].Value
        : user.CreatedAt.ToLocalTime().ToString("dd MMM yyyy");
    var lastUpdated = user == null || user.UpdatedAt == default
        ? S["Unknown"].Value
        : user.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    var avatarUrl = user?.AvatarUrl;
    var initials = GetInitials(displayName);
}

<section class="profile-shell">
    <aside class="profile-sidebar-card">
        <div class="profile-sidebar-top">
            @if (!string.IsNullOrWhiteSpace(avatarUrl))
            {
                <img class="profile-avatar" src="@avatarUrl" alt="@displayName avatar" />
            }
            else
            {
                <div class="profile-avatar-placeholder" aria-label="@displayName initials">@initials</div>
            }

            <div>
                <h1>@displayName</h1>
                <p>@S["ProfileMemberSinceLabel"] @memberSince</p>
            </div>
        </div>

        <nav class="profile-side-nav">
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Profile)" asp-page="/Profile/Index" asp-route-section="profile">@S["ProfileSectionNav_Profile"]</a>
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Recipes)" asp-page="/Profile/Index" asp-route-section="recipes">@S["ProfileSectionNav_Recipes"]</a>
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Reviews)" asp-page="/Profile/Index" asp-route-section="reviews">@S["ProfileSectionNav_Reviews"]</a>
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Edit)" asp-page="/Profile/Index" asp-route-section="edit">@S["ProfileSectionNav_Edit"]</a>
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Photo)" asp-page="/Profile/Index" asp-route-section="photo">@S["ProfileSectionNav_Photo"]</a>
            <a class="@Model.GetSectionClass(CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Password)" asp-page="/Profile/Index" asp-route-section="password">@S["ProfileSectionNav_Password"]</a>
        </nav>
    </aside>

    <section class="profile-content-card">
        <header class="profile-content-header">
            <div>
                <span class="home-card-label">@S["UserArea"]</span>
                <h2>@GetSectionTitle(Model.ActiveSection)</h2>
            </div>
            <p>@GetSectionDescription(Model.ActiveSection)</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="profile-status">@Model.StatusMessage</div>
        }

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        @if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Profile)
        {
            <div class="profile-section-card">
                <dl class="profile-grid">
                    <div class="profile-row">
                        <dt>@S["DisplayName"]</dt>
                        <dd>@displayName</dd>
                    </div>
                    <div class="profile-row">
                        <dt>@S["Email"]</dt>
                        <dd>@(user?.Email ?? S["NotInformed"].Value)</dd>
                    </div>
                    <div class="profile-row">
                        <dt>@S["AvatarSource"]</dt>
                        <dd>@(string.IsNullOrWhiteSpace(user?.AvatarUrl) ? S["NoAvatarConfigured"].Value : user!.AvatarUrl)</dd>
                    </div>
                    <div class="profile-row">
                        <dt>@S["UserId"]</dt>
                        <dd>@(user?.Id.ToString() ?? S["Unknown"].Value)</dd>
                    </div>
                    <div class="profile-row">
                        <dt>@S["CreatedAt"]</dt>
                        <dd>@memberSince</dd>
                    </div>
                    <div class="profile-row">
                        <dt>@S["LastUpdated"]</dt>
                        <dd>@lastUpdated</dd>
                    </div>
                </dl>

                <div class="profile-actions">
                    <a class="profile-link-button" asp-page="/Profile/Index" asp-route-section="edit">@S["EditDetails"]</a>
                    <a class="profile-link-button" asp-page="/Profile/Index" asp-route-section="photo">@S["UpdatePhoto"]</a>
                    <a class="profile-link-button" asp-page="/Profile/Index" asp-route-section="password">@S["UpdatePassword"]</a>
                </div>
            </div>
        }
        else if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Edit)
        {
            <form method="post" asp-page-handler="UpdateProfile" class="profile-form">
                <div class="profile-form-grid">
                    <label class="profile-field">
                        <span>@S["Name"]</span>
                        <input asp-for="ProfileInput.Name" class="profile-input" />
                        <span asp-validation-for="ProfileInput.Name" class="text-danger"></span>
                    </label>

                    <label class="profile-field">
                        <span>@S["Email"]</span>
                        <input asp-for="ProfileInput.Email" class="profile-input" />
                        <span asp-validation-for="ProfileInput.Email" class="text-danger"></span>
                    </label>
                </div>

                <button type="submit" class="profile-submit">@S["SaveDetails"]</button>
            </form>
        }
        else if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Photo)
        {
            <form method="post" asp-page-handler="UpdateAvatar" class="profile-form">
                <label class="profile-field profile-field-full">
                    <span>@S["AvatarUrl"]</span>
                    <input asp-for="AvatarInput.AvatarUrl" class="profile-input" placeholder="@S["AvatarUrlPlaceholder"]" />
                    <span asp-validation-for="AvatarInput.AvatarUrl" class="text-danger"></span>
                </label>

                <p class="profile-helper">@S["AvatarUrlHelp"]</p>

                <button type="submit" class="profile-submit">@S["SavePhoto"]</button>
            </form>
        }
        else if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Password)
        {
            <form method="post" asp-page-handler="ChangePassword" class="profile-form">
                <div class="profile-form-grid">
                    <label class="profile-field profile-field-full">
                        <span>@S["CurrentPassword"]</span>
                        <input asp-for="PasswordInput.CurrentPassword" class="profile-input" />
                        <span asp-validation-for="PasswordInput.CurrentPassword" class="text-danger"></span>
                    </label>

                    <label class="profile-field">
                        <span>@S["NewPassword"]</span>
                        <input asp-for="PasswordInput.NewPassword" class="profile-input" />
                        <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
                    </label>

                    <label class="profile-field">
                        <span>@S["ConfirmPassword"]</span>
                        <input asp-for="PasswordInput.ConfirmPassword" class="profile-input" />
                        <span asp-validation-for="PasswordInput.ConfirmPassword" class="text-danger"></span>
                    </label>
                </div>

                <button type="submit" class="profile-submit">@S["SavePassword"]</button>
            </form>
        }
        else if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Recipes)
        {
            <div class="profile-empty">
                <strong>@S["ProfileRecipesPlaceholder"]</strong>
                <p class="profile-helper">@S["ProfileRecipesPlaceholderDesc"]</p>
            </div>
        }
        else if (Model.ActiveSection == CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Reviews)
        {
            <div class="profile-empty">
                <strong>@S["ProfileReviewsPlaceholder"]</strong>
                <p class="profile-helper">@S["ProfileReviewsPlaceholderDesc"]</p>
            </div>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@functions {
    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
        {
            return "CH";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(parts[0].Length, 2)].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private string GetSectionTitle(string section)
    {
        return section switch
        {
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Edit => S["EditProfileDetails"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Photo => S["UpdateProfilePhoto"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Password => S["UpdatePassword"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Recipes => S["YourRecipes"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Reviews => S["YourReviews"].Value,
            _ => S["Profile"].Value
        };
    }

    private string GetSectionDescription(string section)
    {
        return section switch
        {
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Edit => S["EditProfileDesc"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Photo => S["UpdatePhotoDesc"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Password => S["UpdatePasswordDesc"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Recipes => S["YourRecipesDesc"].Value,
            CoffeeHub.Web.Pages.Profile.IndexModel.ProfileSections.Reviews => S["YourReviewsDesc"].Value,
            _ => S["ProfileDesc"].Value
        };
    }
}
