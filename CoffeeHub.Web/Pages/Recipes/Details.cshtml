@page "{id:guid}"
@model CoffeeHub.Web.Pages.Recipes.DetailsModel
@{
    ViewData["Title"] = S["RecipesDetailsDesc"].Value;
    var recipe = Model.Recipe!;
    var breadcrumbs = new[]
    {
        (S["Home"].Value, "/Home/Index"),
        (S["Recipes"].Value, "/Recipes/Index"),
        (recipe.Title, null)
    };
}

<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["RecipesLibraryLabel"]</span>
        <h1>@recipe.Title</h1>
        <p>@S["RecipesDetailsDesc"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Recipes/Index">@S["BackToList"]</a>
        <a class="coffeehub-nav-button" asp-page="/Recipes/Edit" asp-route-id="@recipe.Id">@S["RecipesEditBtn"]</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="coffee-status">@Model.StatusMessage</div>
}

<section class="coffee-card-shell">
    <dl class="coffee-details-grid">
        <div class="coffee-details-row">
            <dt>@S["Coffee"]</dt>
            <dd>@(recipe.Coffee?.Name ?? recipe.CoffeeId.ToString())</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RecipesBrewingMethod"]</dt>
            <dd>@(recipe.BrewingMethod?.Name ?? recipe.BrewingMethodId.ToString())</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["Description"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(recipe.Description) ? S["RecipesNoDescProvided"].Value : recipe.Description)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RecipesCoffeeAmount"]</dt>
            <dd>@(recipe.CoffeeAmountInGrams?.ToString("0.##") ?? "-") g</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RecipesWaterAmount"]</dt>
            <dd>@(recipe.WaterAmountInMilliliters?.ToString("0.##") ?? "-") ml</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RecipesBrewTime"]</dt>
            <dd>@(recipe.BrewTimeInSeconds?.ToString() ?? "-") s</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RecipesInstructions"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(recipe.Instructions) ? S["RecipesNoInstructions"].Value : recipe.Instructions)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CreatedAt"]</dt>
            <dd>@recipe.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
        </div>
    </dl>

    <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id" data-confirm-message="@S["ConfirmDelete"]">
        <button type="submit" class="coffee-danger">@S["RecipesDeleteBtn"]</button>
    </form>
</section>
