@page
@model CoffeeHub.Web.Pages.Recipes.IndexModel
@{
    ViewData["Title"] = S["RecipesIndexHeading"].Value;
}

<h2>@S["RecipesIndexHeading"]</h2>

@if (!Model.Recipes.Any())
{
    <p class="text-muted">@S["RecipesEmptyDesc"]</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@S["RecipesColTitle"]</th>
                <th>@S["RecipesColCoffee"]</th>
                <th>@S["RecipesColMethod"]</th>
                <th>@S["Created"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var recipe in Model.Recipes)
            {
                <tr>
                    <td>@recipe.Title</td>
                    <td>@(recipe.Coffee?.Name ?? S["Unknown"].Value)</td>
                    <td>@(recipe.BrewingMethod?.Name ?? S["Unknown"].Value)</td>
                    <td>@recipe.CreatedAt.ToString("MMM dd, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
