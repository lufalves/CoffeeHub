@page "{id:guid}"
@model CoffeeHub.Web.Pages.Recipes.EditModel
@{
    ViewData["Title"] = "Edit recipe";
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">Recipe library</span>
        <h1>Edit recipe</h1>
        <p>Update your brewing method, ratios, and instructions.</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Recipes/Index">Back to list</a>
    </div>
</section>

<section class="coffee-card-shell">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form method="post" class="coffee-form">
        <div class="coffee-form-grid">
            <label class="coffee-field">
                <span>Coffee</span>
                <select asp-for="Input.CoffeeId" class="coffee-input">
                    <option value="">Select a coffee</option>
                    @foreach (var coffee in Model.Coffees)
                    {
                        <option value="@coffee.Id">@coffee.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.CoffeeId" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>Brewing method</span>
                <select asp-for="Input.BrewingMethodId" class="coffee-input">
                    <option value="">Select a method</option>
                    @foreach (var method in Model.BrewingMethods)
                    {
                        <option value="@method.Id">@method.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.BrewingMethodId" class="text-danger"></span>
            </label>

            <label class="coffee-field coffee-field-full">
                <span>Title</span>
                <input asp-for="Input.Title" class="coffee-input" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </label>

            <label class="coffee-field coffee-field-full">
                <span>Description</span>
                <textarea asp-for="Input.Description" class="coffee-input coffee-textarea"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>Coffee amount (g)</span>
                <input asp-for="Input.CoffeeAmountInGrams" class="coffee-input" type="number" step="0.1" min="0" />
                <span asp-validation-for="Input.CoffeeAmountInGrams" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>Water amount (ml)</span>
                <input asp-for="Input.WaterAmountInMilliliters" class="coffee-input" type="number" step="0.1" min="0" />
                <span asp-validation-for="Input.WaterAmountInMilliliters" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>Brew time (seconds)</span>
                <input asp-for="Input.BrewTimeInSeconds" class="coffee-input" type="number" min="0" />
                <span asp-validation-for="Input.BrewTimeInSeconds" class="text-danger"></span>
            </label>

            <label class="coffee-field coffee-field-full">
                <span>Instructions</span>
                <textarea asp-for="Input.Instructions" class="coffee-input coffee-textarea"></textarea>
                <span asp-validation-for="Input.Instructions" class="text-danger"></span>
            </label>
        </div>

        <div class="coffee-form-actions">
            <button type="submit" class="coffee-submit">Save changes</button>
            <a class="coffee-link-button" asp-page="/Recipes/Details" asp-route-id="@RouteData.Values["id"]">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
