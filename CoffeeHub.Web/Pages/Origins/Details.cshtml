@page "{id:guid}"
@model CoffeeHub.Web.Pages.Origins.DetailsModel
@{
    ViewData["Title"] = "Origin details";
    var origin = Model.Origin!;
    var breadcrumbs = new[]
    {
        ("Home", "/Home/Index"),
        ("Origins", "/Origins/Index"),
        (origin.Country, null)
    };
}

<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">Reference data</span>
        <h1>@origin.Country</h1>
        <p>@(string.IsNullOrWhiteSpace(origin.Description) ? "No description provided." : origin.Description)</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Origins/Index">Back to origins</a>
    </div>
</section>

<section class="coffee-card-shell mb-4">
    <dl class="coffee-details-grid">
        <div class="coffee-details-row">
            <dt>Region</dt>
            <dd>@(string.IsNullOrWhiteSpace(origin.Region) ? "-" : origin.Region)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>Locality</dt>
            <dd>@(string.IsNullOrWhiteSpace(origin.Locality) ? "-" : origin.Locality)</dd>
        </div>
    </dl>
</section>

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">Catalog</span>
        <h2>Coffees from this origin</h2>
    </div>
</section>

@if (Model.PagedCoffees.Items.Count == 0)
{
    <section class="coffee-empty">
        <h3>No coffees linked to this origin yet.</h3>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Barcode</th>
                    <th>Roastery</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coffee in Model.PagedCoffees.Items)
                {
                    <tr>
                        <td>@coffee.Name</td>
                        <td>@coffee.Barcode</td>
                        <td>@(coffee.Roastery?.Name ?? "Not informed")</td>
                        <td>
                            <a class="coffee-link-button" asp-page="/Coffees/Details" asp-route-id="@coffee.Id">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (Model.PagedCoffees.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.PagedCoffees.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Origins/Details" asp-route-id="@origin.Id" asp-route-page="@(Model.PagedCoffees.Page - 1)">Previous</a>
                    </li>
                }
                @for (var coffeePg = 1; coffeePg <= Model.PagedCoffees.TotalPages; coffeePg++)
                {
                    <li class="page-item @(coffeePg == Model.PagedCoffees.Page ? "active" : string.Empty)">
                        <a class="page-link" asp-page="/Origins/Details" asp-route-id="@origin.Id" asp-route-page="@coffeePg">@coffeePg</a>
                    </li>
                }
                @if (Model.PagedCoffees.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Origins/Details" asp-route-id="@origin.Id" asp-route-page="@(Model.PagedCoffees.Page + 1)">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
