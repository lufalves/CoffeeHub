@page
@model CoffeeHub.Web.Pages.Origins.IndexModel
@{
    ViewData["Title"] = S["Origins"].Value;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["OriginsReferenceLabel"]</span>
        <h1>@S["OriginsIndexHeading"]</h1>
        <p>@S["OriginsIndexDesc"]</p>
    </div>
</section>

@if (Model.Origins.Count == 0)
{
    <section class="coffee-empty">
        <h2>@S["OriginsEmptyTitle"]</h2>
        <p class="coffee-form-helper">@S["OriginsEmptyDesc"]</p>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>@S["OriginsColCountry"]</th>
                    <th>@S["OriginsColRegion"]</th>
                    <th>@S["OriginsColLocality"]</th>
                    <th>@S["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var origin in Model.Origins)
                {
                    <tr>
                        <td>@origin.Country</td>
                        <td>@(string.IsNullOrWhiteSpace(origin.Region) ? "-" : origin.Region)</td>
                        <td>@(string.IsNullOrWhiteSpace(origin.Locality) ? "-" : origin.Locality)</td>
                        <td>
                            <a class="coffee-link-button" asp-page="/Origins/Details" asp-route-id="@origin.Id">@S["Details"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}
