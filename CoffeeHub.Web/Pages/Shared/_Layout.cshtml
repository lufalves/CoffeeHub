<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoffeeHub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoffeeHub.styles.css" asp-append-version="true" />
</head>
<body class="coffeehub-body">
    <header>
        <nav class="navbar navbar-expand-sm coffeehub-nav">
            <div class="container coffeehub-nav-shell">
                <a class="navbar-brand" asp-area="" asp-page="/Index">CoffeeHub</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link coffeehub-nav-link" asp-area="" asp-page="/Home/Index">Home</a>
                        </li>
                    </ul>
                    <div class="coffeehub-nav-actions">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="coffeehub-user-badge">@User.Identity.Name</span>
                            <form method="post" asp-page="/Account/Logout">
                                <button type="submit" class="coffeehub-nav-button">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="coffeehub-nav-link" asp-area="" asp-page="/Account/Login">Login</a>
                            <a class="coffeehub-nav-button" asp-area="" asp-page="/Account/Register">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container coffeehub-main-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer coffeehub-footer">
        <div class="container">
            &copy; 2026 - CoffeeHub - A coffee platform for cataloging, reviewing, and brewing.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
