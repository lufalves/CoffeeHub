@page "{id:guid}"
@model CoffeeHub.Web.Pages.Roasteries.DetailsModel
@{
    ViewData["Title"] = S["Roastery"].Value;
    var roastery = Model.Roastery!;
    var breadcrumbs = new[]
    {
        (S["Home"].Value, "/Home/Index"),
        (S["Roasteries"].Value, "/Roasteries/Index"),
        (roastery.Name, null)
    };
}

<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["OriginsReferenceLabel"]</span>
        <h1>@roastery.Name</h1>
        <p>@(string.IsNullOrWhiteSpace(roastery.Description) ? S["RoasteriesNoDesc"].Value : roastery.Description)</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Roasteries/Index">@S["RoasteriesBackBtn"]</a>
    </div>
</section>

<section class="coffee-card-shell mb-4">
    <dl class="coffee-details-grid">
        <div class="coffee-details-row">
            <dt>@S["RoasteriesColWebsite"]</dt>
            <dd>
                @if (string.IsNullOrWhiteSpace(roastery.WebsiteUrl))
                {
                    <span>-</span>
                }
                else
                {
                    <a href="@roastery.WebsiteUrl" target="_blank" rel="noopener noreferrer">@roastery.WebsiteUrl</a>
                }
            </dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["RoasteriesColInstagram"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(roastery.InstagramUrl) ? "-" : roastery.InstagramUrl)</dd>
        </div>
    </dl>
</section>

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["Catalog"]</span>
        <h2>@S["RoasteriesFromThisRoastery"]</h2>
    </div>
</section>

@if (Model.PagedCoffees.Items.Count == 0)
{
    <section class="coffee-empty">
        <h3>@S["RoasteriesNoCoffeesLinked"]</h3>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>@S["Name"]</th>
                    <th>@S["Barcode"]</th>
                    <th>@S["RoasteriesColOrigin"]</th>
                    <th>@S["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coffee in Model.PagedCoffees.Items)
                {
                    <tr>
                        <td>@coffee.Name</td>
                        <td>@coffee.Barcode</td>
                        <td>@(coffee.Origin?.Country ?? S["NotInformed"].Value)</td>
                        <td>
                            <a class="coffee-link-button" asp-page="/Coffees/Details" asp-route-id="@coffee.Id">@S["Details"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (Model.PagedCoffees.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.PagedCoffees.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Roasteries/Details" asp-route-id="@roastery.Id" asp-route-page="@(Model.PagedCoffees.Page - 1)">@S["Previous"]</a>
                    </li>
                }
                @for (var coffeePg = 1; coffeePg <= Model.PagedCoffees.TotalPages; coffeePg++)
                {
                    <li class="page-item @(coffeePg == Model.PagedCoffees.Page ? "active" : string.Empty)">
                        <a class="page-link" asp-page="/Roasteries/Details" asp-route-id="@roastery.Id" asp-route-page="@coffeePg">@coffeePg</a>
                    </li>
                }
                @if (Model.PagedCoffees.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Roasteries/Details" asp-route-id="@roastery.Id" asp-route-page="@(Model.PagedCoffees.Page + 1)">@S["Next"]</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
