@page
@model CoffeeHub.Web.Pages.Roasteries.IndexModel
@{
    ViewData["Title"] = S["Roasteries"].Value;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["OriginsReferenceLabel"]</span>
        <h1>@S["RoasteriesIndexHeading"]</h1>
        <p>@S["RoasteriesIndexDesc"]</p>
    </div>
</section>

@if (Model.Roasteries.Count == 0)
{
    <section class="coffee-empty">
        <h2>@S["RoasteriesEmptyTitle"]</h2>
        <p class="coffee-form-helper">@S["RoasteriesEmptyDesc"]</p>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>@S["Name"]</th>
                    <th>@S["RoasteriesColWebsite"]</th>
                    <th>@S["RoasteriesColInstagram"]</th>
                    <th>@S["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var roastery in Model.Roasteries)
                {
                    <tr>
                        <td>@roastery.Name</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(roastery.WebsiteUrl))
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a href="@roastery.WebsiteUrl" target="_blank" rel="noopener noreferrer">@roastery.WebsiteUrl</a>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(roastery.InstagramUrl) ? "-" : roastery.InstagramUrl)</td>
                        <td>
                            <a class="coffee-link-button" asp-page="/Roasteries/Details" asp-route-id="@roastery.Id">@S["Details"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}
