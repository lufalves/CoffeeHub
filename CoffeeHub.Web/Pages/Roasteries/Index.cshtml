@page
@model CoffeeHub.Web.Pages.Roasteries.IndexModel
@{
    ViewData["Title"] = "Roasteries";
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">Reference data</span>
        <h1>Roasteries</h1>
        <p>Browse all registered roasteries and open details to view related coffees.</p>
    </div>
</section>

@if (Model.Roasteries.Count == 0)
{
    <section class="coffee-empty">
        <h2>No roasteries found</h2>
        <p class="coffee-form-helper">Reference data appears empty for this environment.</p>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Website</th>
                    <th>Instagram</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var roastery in Model.Roasteries)
                {
                    <tr>
                        <td>@roastery.Name</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(roastery.WebsiteUrl))
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a href="@roastery.WebsiteUrl" target="_blank" rel="noopener noreferrer">@roastery.WebsiteUrl</a>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(roastery.InstagramUrl) ? "-" : roastery.InstagramUrl)</td>
                        <td>
                            <a class="coffee-link-button" asp-page="/Roasteries/Details" asp-route-id="@roastery.Id">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}
