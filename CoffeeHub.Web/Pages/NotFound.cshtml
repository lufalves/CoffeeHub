@page
@model CoffeeHub.Web.Pages.NotFoundModel
@{
    ViewData["Title"] = S["NotFoundTitle"].Value;
}

<section class="error-shell">
    <span class="home-card-label">@S["NotFoundCode"]</span>
    <h1>@S["NotFoundTitle"]</h1>
    <p>@S["NotFoundDesc"]</p>
    <div class="coffee-form-actions">
        <a class="coffeehub-nav-button" asp-page="/Home/Index">@S["NotFoundGoHome"]</a>
        <a class="coffee-link-button" asp-page="/Coffees/Index">@S["NotFoundBrowseCoffees"]</a>
    </div>
</section>
