@page
@model CoffeeHub.Web.Pages.Coffees.IndexModel
@{
    ViewData["Title"] = "Coffees";
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">Coffee catalog</span>
        <h1>All coffees</h1>
        <p>Basic management screen for the catalog with navigation to register, inspect, and update each coffee.</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffeehub-nav-button" asp-page="/Coffees/Create">Register coffee</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="coffee-status">@Model.StatusMessage</div>
}

@if (Model.PagedCoffees.Items.Count == 0)
{
    <section class="coffee-empty">
        <h2>No coffees registered yet</h2>
        <p class="coffee-form-helper">Create the first entry to start using the catalog workflow.</p>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>Barcode</th>
                    <th>Name</th>
                    <th>Roastery Id</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coffee in Model.PagedCoffees.Items)
                {
                    <tr>
                        <td>@coffee.Barcode</td>
                        <td>@coffee.Name</td>
                        <td>@coffee.RoasteryId</td>
                        <td>@coffee.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="coffee-table-actions">
                                <a class="coffee-link-button" asp-page="/Coffees/Details" asp-route-id="@coffee.Id">Details</a>
                                <a class="coffee-link-button" asp-page="/Coffees/Edit" asp-route-id="@coffee.Id">Edit</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (Model.PagedCoffees.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @if (Model.PagedCoffees.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@(Model.PagedCoffees.Page - 1)">Previous</a>
                    </li>
                }
                @for (int i = 1; i <= Model.PagedCoffees.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagedCoffees.Page ? "active" : "")">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.PagedCoffees.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@(Model.PagedCoffees.Page + 1)">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
