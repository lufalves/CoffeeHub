@page
@model CoffeeHub.Web.Pages.Coffees.IndexModel
@{
    ViewData["Title"] = S["Coffees"].Value;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["CoffeesCatalogLabel"]</span>
        <h1>@S["CoffeesIndexHeading"]</h1>
        <p>@S["CoffeesIndexDesc"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffeehub-nav-button" asp-page="/Coffees/Create">@S["CoffeesRegisterBtn"]</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="coffee-status">@Model.StatusMessage</div>
}

@if (Model.PagedCoffees.Items.Count == 0)
{
    <section class="coffee-empty">
        <h2>@S["CoffeesEmptyTitle"]</h2>
        <p class="coffee-form-helper">@S["CoffeesEmptyDesc"]</p>
    </section>
}
else
{
    <section class="coffee-table-shell">
        <table class="coffee-table">
            <thead>
                <tr>
                    <th>@S["Barcode"]</th>
                    <th>@S["Name"]</th>
                    <th>@S["CoffeesColRoasteryId"]</th>
                    <th>@S["Created"]</th>
                    <th>@S["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coffee in Model.PagedCoffees.Items)
                {
                    <tr>
                        <td>@coffee.Barcode</td>
                        <td>@coffee.Name</td>
                        <td>@coffee.RoasteryId</td>
                        <td>@coffee.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="coffee-table-actions">
                                <a class="coffee-link-button" asp-page="/Coffees/Details" asp-route-id="@coffee.Id">@S["Details"]</a>
                                <a class="coffee-link-button" asp-page="/Coffees/Edit" asp-route-id="@coffee.Id">@S["Edit"]</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (Model.PagedCoffees.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @if (Model.PagedCoffees.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@(Model.PagedCoffees.Page - 1)">@S["Previous"]</a>
                    </li>
                }
                @for (int i = 1; i <= Model.PagedCoffees.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagedCoffees.Page ? "active" : "")">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.PagedCoffees.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Coffees/Index" asp-route-page="@(Model.PagedCoffees.Page + 1)">@S["Next"]</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
