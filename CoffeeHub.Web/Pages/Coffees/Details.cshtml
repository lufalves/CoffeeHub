@page "{id:guid}"
@model CoffeeHub.Web.Pages.Coffees.DetailsModel
@{
    ViewData["Title"] = S["Details"].Value;
    var coffee = Model.Coffee!;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["CoffeesCatalogLabel"]</span>
        <h1>@coffee.Name</h1>
        <p>@S["CoffeesDetailsLabel"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Coffees/Index">@S["BackToList"]</a>
        <a class="coffeehub-nav-button" asp-page="/Coffees/Edit" asp-route-id="@coffee.Id">@S["CoffeesEditCoffeeBtn"]</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="coffee-status">@Model.StatusMessage</div>
}

<section class="coffee-card-shell">
    <dl class="coffee-details-grid">
        <div class="coffee-details-row">
            <dt>@S["Barcode"]</dt>
            <dd>@coffee.Barcode</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["Name"]</dt>
            <dd>@coffee.Name</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["Description"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(coffee.Description) ? S["CoffeesNoDescRegistered"].Value : coffee.Description)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesColRoasteryId"]</dt>
            <dd>@coffee.RoasteryId</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesOriginId"]</dt>
            <dd>@(coffee.OriginId?.ToString() ?? S["NotInformed"].Value)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesFarmId"]</dt>
            <dd>@(coffee.FarmId?.ToString() ?? S["NotInformed"].Value)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesBeanVarietyId"]</dt>
            <dd>@(coffee.BeanVarietyId?.ToString() ?? S["NotInformed"].Value)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesRoastLevelId"]</dt>
            <dd>@(coffee.RoastLevelId?.ToString() ?? S["NotInformed"].Value)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CreatedAt"]</dt>
            <dd>@coffee.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CoffeesUpdatedAt"]</dt>
            <dd>@coffee.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
        </div>
    </dl>

    <form method="post" asp-page-handler="Delete" asp-route-id="@coffee.Id">
        <button type="submit" class="coffee-danger">@S["CoffeesDeleteBtn"]</button>
    </form>
</section>
