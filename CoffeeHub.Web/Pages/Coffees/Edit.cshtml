@page "{id:guid}"
@model CoffeeHub.Web.Pages.Coffees.EditModel
@{
    ViewData["Title"] = S["CoffeesEditHeading"].Value;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["CoffeesCatalogLabel"]</span>
        <h1>@S["CoffeesEditHeading"]</h1>
        <p>@S["CoffeesEditDesc"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Coffees/Index">@S["BackToList"]</a>
    </div>
</section>

<section class="coffee-card-shell">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form method="post" class="coffee-form">
        <div class="coffee-form-grid">
            <label class="coffee-field">
                <span>@S["Barcode"]</span>
                <input asp-for="Input.Barcode" class="coffee-input" />
                <span asp-validation-for="Input.Barcode" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["Name"]</span>
                <input asp-for="Input.Name" class="coffee-input" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </label>

            <label class="coffee-field coffee-field-full">
                <span>@S["Description"]</span>
                <textarea asp-for="Input.Description" class="coffee-input coffee-textarea"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["CoffeesColRoasteryId"]</span>
                <input asp-for="Input.RoasteryId" class="coffee-input" />
                <span asp-validation-for="Input.RoasteryId" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["CoffeesOriginId"]</span>
                <input asp-for="Input.OriginId" class="coffee-input" />
                <span asp-validation-for="Input.OriginId" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["CoffeesFarmId"]</span>
                <input asp-for="Input.FarmId" class="coffee-input" />
                <span asp-validation-for="Input.FarmId" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["CoffeesBeanVarietyId"]</span>
                <input asp-for="Input.BeanVarietyId" class="coffee-input" />
                <span asp-validation-for="Input.BeanVarietyId" class="text-danger"></span>
            </label>

            <label class="coffee-field">
                <span>@S["CoffeesRoastLevelId"]</span>
                <input asp-for="Input.RoastLevelId" class="coffee-input" />
                <span asp-validation-for="Input.RoastLevelId" class="text-danger"></span>
            </label>
        </div>

        <div class="coffee-form-actions">
            <button type="submit" class="coffee-submit">@S["CoffeesSaveChangesBtn"]</button>
            <a class="coffee-link-button" asp-page="/Coffees/Details" asp-route-id="@RouteData.Values["id"]">@S["Cancel"]</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
