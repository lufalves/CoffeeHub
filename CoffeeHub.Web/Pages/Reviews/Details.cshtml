@page "{id:guid}"
@model CoffeeHub.Web.Pages.Reviews.DetailsModel
@{
    ViewData["Title"] = S["ReviewsDetailsHeading"].Value;
    var review = Model.Review!;
    var breadcrumbs = new[]
    {
        (S["Home"].Value, "/Home/Index"),
        (S["Reviews"].Value, "/Reviews/Index"),
        ($"{S["ReviewsDetailsHeading"].Value} - {review.Rating:0.0}", null)
    };
}

<partial name="_Breadcrumb" model="breadcrumbs" />

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["ReviewsLogLabel"]</span>
        <h1>@S["ReviewsDetailsHeading"]</h1>
        <p>@S["ReviewsDetailsDesc"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Reviews/Index">@S["BackToList"]</a>
        <a class="coffeehub-nav-button" asp-page="/Reviews/Edit" asp-route-id="@review.Id">@S["ReviewsEditBtn"]</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="coffee-status">@Model.StatusMessage</div>
}

<section class="coffee-card-shell">
    <dl class="coffee-details-grid">
        <div class="coffee-details-row">
            <dt>@S["Coffee"]</dt>
            <dd>@(review.Coffee?.Name ?? review.CoffeeId.ToString())</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["Rating"]</dt>
            <dd>@BuildStars(review.Rating) (@review.Rating.ToString("0.0") / 5)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["Comment"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(review.Comment) ? S["ReviewsNoComment"].Value : review.Comment)</dd>
        </div>
        <div class="coffee-details-row">
            <dt>@S["CreatedAt"]</dt>
            <dd>@review.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
        </div>
    </dl>

    <form method="post" asp-page-handler="Delete" asp-route-id="@review.Id" data-confirm-message="@S["ConfirmDelete"]">
        <button type="submit" class="coffee-danger">@S["ReviewsDeleteBtn"]</button>
    </form>
</section>

@functions {
    private static string BuildStars(decimal rating)
    {
        var rounded = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        rounded = Math.Clamp(rounded, 1, 5);
        return new string('★', rounded) + new string('☆', 5 - rounded);
    }
}
