@page
@model CoffeeHub.Web.Pages.Reviews.CreateModel
@{
    ViewData["Title"] = S["ReviewsCreateHeading"].Value;
}

<section class="coffee-page-header">
    <div>
        <span class="home-card-label">@S["ReviewsLogLabel"]</span>
        <h1>@S["ReviewsCreateHeading"]</h1>
        <p>@S["ReviewsCreateDesc"]</p>
    </div>
    <div class="coffee-page-actions">
        <a class="coffee-link-button" asp-page="/Reviews/Index">@S["BackToList"]</a>
    </div>
</section>

<section class="coffee-card-shell">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form method="post" class="coffee-form">
        <div class="coffee-form-grid">
            <label class="coffee-field coffee-field-full">
                <span>@S["Coffee"]</span>
                <select asp-for="Input.CoffeeId" class="coffee-input">
                    <option value="">@S["ReviewsSelectCoffee"]</option>
                    @foreach (var coffee in Model.Coffees)
                    {
                        <option value="@coffee.Id">@coffee.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.CoffeeId" class="text-danger"></span>
            </label>

            <div class="coffee-field coffee-field-full">
                <span>@S["Rating"]</span>
                <div class="review-stars">
                    @for (var value = 5; value >= 1; value--)
                    {
                        var inputId = $"rating-{value}";
                        <input id="@inputId" class="review-star-input" asp-for="Input.Rating" type="radio" value="@value" />
                        <label class="review-star-label" for="@inputId" title="@($"{value} stars")">★</label>
                    }
                </div>
                <span asp-validation-for="Input.Rating" class="text-danger"></span>
            </div>

            <label class="coffee-field coffee-field-full">
                <span>@S["Comment"]</span>
                <textarea asp-for="Input.Comment" class="coffee-input coffee-textarea"></textarea>
                <span asp-validation-for="Input.Comment" class="text-danger"></span>
            </label>
        </div>

        <div class="coffee-form-actions">
            <button type="submit" class="coffee-submit">@S["ReviewsSaveBtn"]</button>
            <a class="coffee-link-button" asp-page="/Reviews/Index">@S["Cancel"]</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
